rules_version = '2';

// Capture the King — Firestore security rules.
//
// The game server (Firebase Admin SDK) is the ONLY writer. Admin SDK access
// bypasses these rules entirely, so every `allow write` below is intentionally
// denied: no client may ever write game state or stats.
//
// Reads are scoped to the owning/participating user so a future client-side
// /history screen can read directly without exposing other players' data. The
// current web client reads nothing from Firestore (it goes through the socket),
// so these read rules are forward-compatible, not load-bearing yet.
service cloud.firestore {
  match /databases/{database}/documents {

    // A user's own profile + aggregate stats. Self-read only; never client-writable.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Finished games. Readable only by the two participants; never client-writable.
    match /games/{gameId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.players.w.uid ||
        request.auth.uid == resource.data.players.b.uid
      );
      allow write: if false;
    }

    // Default deny for anything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
