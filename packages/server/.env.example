# Port the HTTP+WebSocket server listens on (default 8080).
PORT=8080

# Allowed CORS origin for the web client (default *). Set to your web URL in prod.
WEB_ORIGIN=http://localhost:5173

# --- Firebase Admin (required) ---
# Provide ONE of the following so the server can verify Firebase ID tokens.
#
# Option A: the service-account JSON inline (or base64 of it). Easiest for containers.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}
#
# Option B: path to the service-account JSON file (Google Application Default Creds).
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
