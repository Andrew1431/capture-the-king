# URL of the @ctk/server WebSocket endpoint. Defaults to http://localhost:8080.
VITE_SERVER_URL=http://localhost:8080

# Firebase web config (public — safe to ship in the bundle).
# Copy these from Firebase console → Project settings → Your apps → SDK setup.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Enables Firebase Analytics (GA4). Format: G-XXXXXXXXXX. Leave blank to disable.
VITE_FIREBASE_MEASUREMENT_ID=
